<form action="" method="post">
    <table>
        <tr>
            <td>
                <textarea name="notebody" id="notebody" class="pr-body" cols="14" rows="4" style="
resize:none;
width:175px; height:175px;
  padding:10px;
  overflow:hidden;
	background-color:#eee;
  cursor:move;
  font-family:Trebuchet MS,Tahoma,Myriad Pro,Arial,Verdana,sans-serif;
  font-size:16px;
  border:1px solid #999;
">
                    {{ task.beschreibung|default('')|raw }}
                </textarea>
            </td>
        </tr>
        <tr>
            <td align="right">
                Farbe:
                <select id="paddnotecolor" name="color">
                    <option value="yellow">Orange</option>
                    <option value="blue">Blau</option>
                    <option value="green">Gr&uuml;n</option>
                    <option value="coral">Violett</option>
                </select>
            </td>
        </tr>
        <tr height="50">
            <td>
                <br><br>
                <input type="submit" value="Speichern" name="submit">
                <br><br>
                <i>Bitte max. 4 Zeilen eingeben</i><br><br>
            </td>
        </tr>
    </table>
</form>
{% if task.note_color is defined %}
<script type="text/javascript">
    $(document).ready(function() {
      $('#paddnotecolor').val('{{ task.note_color }}');
    });
</script>
{% endif %}
